{
	"name": "fileclass",
	"version": "0.0.1",
	"description": "Schemas, typed fields & data quality for your Obsidian vault — powered by Bases.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"typecheck": "tsc -noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "node tests/e2e/canary.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"metadata",
		"bases",
		"schema"
	],
	"author": "mdelobelle",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.0.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.20.0",
		"obsidian": "^1.7.2",
		"tslib": "^2.6.0",
		"typescript": "^5.4.0",
		"vitest": "^2.0.0"
	}
}
